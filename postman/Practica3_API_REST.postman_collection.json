    {
      "name": "Users - Correccion POST",
      "item": [
        {
          "name": "POST /api/users - ID generado automaticamente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mateo Orellana\",\n  \"email\": \"mateo.orellana@ups.edu.ec\",\n  \"password\": \"12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"La respuesta tiene ID y no expone password\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json).not.to.have.property(\"password\");",
                  "    pm.expect(json).not.to.have.property(\"passwordHash\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
