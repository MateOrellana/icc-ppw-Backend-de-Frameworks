{
  "info": {
    "_postman_id": "5d3475c7-9bd9-4a74-9b3c-practica6dto",
    "name": "Practica 6 - DTOs y Validacion",
    "description": "Coleccion para validar DTOs, reglas de negocio y eliminacion logica de productos. Autor: Mateo Orellana.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "validationProductId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Productos - Validacion y reglas",
      "item": [
        {
          "name": "POST /api/products - Error por datos invalidos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"price\": -5,\n  \"stock\": -1\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Debe responder 400\", function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/products - Crear producto valido para pruebas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor Samsung\",\n  \"price\": 230.75,\n  \"stock\": 8\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Debe crear el producto\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set(\"validationProductId\", data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE /api/products/{{validationProductId}} - Eliminacion logica",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products/{{validationProductId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products",
                "{{validationProductId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Debe eliminar logicamente\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PUT /api/products/{{validationProductId}} - Error al actualizar eliminado",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor Samsung actualizado\",\n  \"price\": 250.00,\n  \"stock\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/products/{{validationProductId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products",
                "{{validationProductId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Debe responder error de negocio\", function () {",
                  "  pm.expect([400, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test(\"Debe indicar que el producto no esta disponible\", function () {",
                  "  pm.expect(pm.response.text()).to.satisfy(text =>",
                  "    text.includes(\"Product already deleted\") || text.includes(\"Product not found\")",
                  "  );",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /api/products - No debe listar productos eliminados",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Debe responder 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"No incluye el producto eliminado\", function () {",
                  "  const products = pm.response.json();",
                  "  const deletedId = Number(pm.collectionVariables.get(\"validationProductId\"));",
                  "  pm.expect(products.some(product => product.id === deletedId)).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
